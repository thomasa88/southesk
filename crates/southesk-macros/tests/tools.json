{
  "tools": [
    {
      "name": "simple_tool",
      "description": "A simple tool.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "input": {
            "description": "The input string.",
            "type": "string"
          }
        },
        "required": [
          "input"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "output": {
            "type": "number"
          }
        },
        "required": [
          "output"
        ]
      }
    },
    {
      "name": "other_tool",
      "description": "Another tool.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "input": {
            "description": "The input value.",
            "type": "string",
            "enum": [
              "Value1",
              "Value2",
              "Value3"
            ]
          }
        },
        "required": [
          "input"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "output": {
            "description": "The output number.",
            "type": "number"
          },
          "parent": {
            "description": "Nested parent",
            "type": "object",
            "properties": {
              "child": {
                "description": "Nested child",
                "type": "object",
                "properties": {
                  "innermost": {
                    "description": "Innermost child",
                    "type": "number"
                  }
                },
                "required": [
                  "innermost"
                ]
              }
            }
          }
        },
        "required": [
          "output"
        ]
      }
    }
  ]
