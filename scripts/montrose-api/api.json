  "tools": [
    {
      "name": "get_holdings",
      "description": "Returns holdings for either one account (when accountId is provided) or all accessible accounts. Each account includes currencyPositions: the account's multi-currency cash balances with the amount available for purchase per currency. An empty currencyPositions list means the account holds cash only in its main currency (see the summary). Use GetUserAccounts first to find valid account IDs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "accountId": {
            "description": "Optional account ID as a UUID/GUID string (e.g. \"3fa85f64-5717-4562-b3fc-2c963f66afa6\"). Use GetUserAccounts to find valid account IDs. If omitted, holdings are returned for all accessible accounts.",
            "type": [
              "string",
              "null"
            ],
            "format": "uuid",
            "default": null
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "result": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "accountId": {
                  "type": "string"
                },
                "accountNumber": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "accountName": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "accountType": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "currency": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "summary": {
                  "type": [
                    "object",
                    "null"
                  ],
                  "properties": {
                    "totalMarketValue": {
                      "type": "number"
                    },
                    "availableForPurchase": {
                      "type": "number"
                    },
                    "totalValue": {
                      "type": "number"
                    },
                    "currency": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "totalMarketValue",
                    "availableForPurchase",
                    "totalValue",
                    "currency"
                  ]
                },
                "currencyPositions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "currencyCode": {
                        "type": "string"
                      },
                      "balance": {
                        "type": "number"
                      },
                      "accruedInterest": {
                        "type": "number"
                      },
                      "availableForPurchase": {
                        "type": "number"
                      }
                    },
                    "required": [
                      "currencyCode",
                      "balance",
                      "accruedInterest",
                      "availableForPurchase"
                    ]
                  }
                },
                "positions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "instrumentName": {
                        "type": "string"
                      },
                      "ticker": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "orderbookId": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "possibleOrderbookIds": {
                        "type": [
                          "array",
                          "null"
                        ],
                        "items": {
                          "type": "integer"
                        }
                      },
                      "quantity": {
                        "type": "number"
                      },
                      "marketValue": {
                        "type": [
                          "object",
                          "null"
                        ],
                        "properties": {
                          "accountCurrency": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "instrumentCurrency": {
                            "type": [
                              "number",
                              "null"
                            ]
                          }
                        },
                        "required": [
                          "accountCurrency",
                          "instrumentCurrency"
                        ]
                      },
                      "unrealizedResult": {
                        "type": [
                          "object",
                          "null"
                        ],
                        "properties": {
                          "accountCurrency": {
                            "type": [
                              "number",
                              "null"
                            ]
                          },
                          "instrumentCurrency": {
                            "type": [
                              "number",
                              "null"
                            ]
                          }
                        },
                        "required": [
                          "accountCurrency",
                          "instrumentCurrency"
                        ]
                      },
                      "unrealizedResultPercent": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "instrumentCurrency": {
                        "type": "string"
                      },
                      "fxRate": {
                        "type": [
                          "number",
                          "null"
                        ]
                      }
                    },
                    "required": [
                      "instrumentName",
                      "ticker",
                      "orderbookId",
                      "possibleOrderbookIds",
                      "quantity",
                      "marketValue",
                      "unrealizedResult",
                      "unrealizedResultPercent",
                      "instrumentCurrency",
                      "fxRate"
                    ]
                  }
                },
                "error": {
                  "type": [
                    "string",
                    "null"
                  ]
